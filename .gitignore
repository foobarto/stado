/stado
*.db
*.log
.stado/

# Agent assistant config — local development tooling for AI coding
# assistants (Codex, Claude Code, etc). Not stado source.
/AGENTS.md
/CLAUDE.md
.claude/

# Binary blobs fetched by `go run hack/fetch-binaries.go` + the per-
# platform embed files it generates. Release builds run the script as
# a goreleaser before-hook; dev builds don't need them.
/internal/tools/rg/bundled/*
!/internal/tools/rg/bundled/.gitkeep
/internal/tools/rg/bundled_*_*.go
/internal/tools/astgrep/bundled/*
!/internal/tools/astgrep/bundled/.gitkeep
/internal/tools/astgrep/bundled_*_*.go

# Example-plugin build artefacts (committed source + manifest template
# only; build.sh regenerates these).
/examples/plugins/*/plugin.wasm
/examples/plugins/*/plugin.manifest.json
/examples/plugins/*/plugin.manifest.sig
/examples/plugins/*/*.seed
/examples/plugins/*/*.o
/examples/plugins/*/go.sum
/examples/plugins/*/.zig-cache/
/examples/plugins/*/zig-cache/
/examples/plugins/*/zig-out/
.env
