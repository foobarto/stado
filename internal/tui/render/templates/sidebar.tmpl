{{- /* Right sidebar — current state, risks, agent inputs, repo, todo. */ -}}
{{ color "text" .Title | bold }}
{{- if .SessionLabel }}
{{ color "text_secondary" (wrapHard .SessionLabel .Width) }}
{{- end }}
{{- if .SessionMeta }}
{{ color "text_dim" (wrapHard .SessionMeta .Width) }}
{{- end }}

{{- if .NowLines }}

{{ color "text" "Now" | bold }}
{{- range .NowLines }}
{{ color .Tone (wrapHard .Text $.Width) }}
{{- end }}
{{- end }}

{{- if .Subagents }}

{{ color "text" "Subagents" | bold }}
{{- range .Subagents }}
{{ color .Tone (wrapHard .Text $.Width) }}
{{- end }}
{{- end }}

{{- if .RiskLines }}

{{ color "text" "Risk" | bold }}
{{- range .RiskLines }}
{{ color .Tone (wrapHard .Text $.Width) }}
{{- end }}
{{- end }}

{{- if .AgentLines }}

{{ color "text" "Agent" | bold }}
{{- range .AgentLines }}
{{ color .Tone (wrapHard .Text $.Width) }}
{{- end }}
{{- end }}

{{- if .RepoLines }}

{{ color "text" "Repo" | bold }}
{{- range .RepoLines }}
{{ color .Tone (wrapHard .Text $.Width) }}
{{- end }}
{{- end }}

{{- if .LogLines }}

{{ color "text" "Logs" | bold }}
{{- range .LogLines }}
{{ color .Tone (wrapHard .Text $.Width) }}
{{- end }}
{{- end }}

{{- if or .TodoSummary .Todos }}

{{ color "text" "Todo" | bold }}
{{- if .TodoSummary }}
{{ color "muted" (wrapHard .TodoSummary $.Width) }}
{{- end }}
{{- range .Todos }}
{{ todoMarker .Status }} {{ color (todoColor .Status) (wrapHard .Title $.Width) }}
{{- end }}
{{- end }}

{{ color "text_dim" .Version }}
