{{- /* Right sidebar — Context + Cwd + Model + Todo + version. */ -}}
{{ color "primary" .Title | bold }}
{{- if .SessionLabel }}
{{ color "text_secondary" (wrapHard .SessionLabel .Width) }}
{{- end }}

{{ color "text_secondary" "Context" | bold }}
{{ color "text" .TokensHuman }}
{{ color "muted" .TokenPercent }}
{{ color "accent" .CostHuman }}
{{- if .Cwd }}

{{ color "text_secondary" "Cwd" | bold }}
{{ color "muted" (wrapHard .Cwd .Width) }}
{{- end }}
{{- if .InstructionsName }}

{{ color "text_secondary" "Instructions" | bold }}
{{ color "muted" .InstructionsName }}
{{- end }}
{{- if .SkillsCount }}

{{ color "text_secondary" "Skills" | bold }}
{{ color "muted" .SkillsCount }}
{{- end }}

{{ color "text_secondary" "Model" | bold }}
{{ color "text" .Model }}
{{ color "muted" .ProviderName }}
{{- if .Todos }}

{{ color "text_secondary" "Todo" | bold }}
{{- range .Todos }}
{{ todoMarker .Status }} {{ color (todoColor .Status) (wrapHard .Title $.Width) }}
{{- end }}
{{- end }}

{{ color "text_dim" .Version }}
