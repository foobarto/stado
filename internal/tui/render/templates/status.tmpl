{{- /* Bottom status strip — right-aligned tokens/cost + keybind hint, muted.
       Left side (state dot + message) appears only when not idle. */ -}}
{{- $dot := "●" -}}
{{- if eq .State "streaming" }}{{ color "warning" $dot }} {{ color "muted" "thinking" }}  {{ end -}}
{{- if eq .State "approval" }}{{ color "warning" $dot }} {{ color "muted" "awaiting approval" }}  {{ end -}}
{{- if eq .State "error" }}{{ color "error" $dot }} {{ color "muted" .ErrorMessage }}  {{ end -}}
{{ color "muted" .Tokens }} {{ color "muted" "·" }} {{ color "muted" .Cost }}  {{ color "text_secondary" "ctrl+p" | bold }} {{ color "muted" "commands" }}
